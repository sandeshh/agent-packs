{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpacks.dev/schemas/agent-pack.schema.json",
  "title": "Agent Pack",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "description"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "maintainers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stability": {
      "type": "string",
      "enum": [
        "experimental",
        "stable",
        "deprecated"
      ]
    },
    "deprecated": {
      "type": "boolean"
    },
    "replacement": {
      "type": "string"
    },
    "lastVerified": {
      "type": "string"
    },
    "reviewStatus": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "verified"
      ]
    },
    "requirements": {
      "$ref": "#/$defs/requirements"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "packs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillRef"
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginRef"
      }
    },
    "upstreamSource": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "required": [
        "type",
        "name",
        "source"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "skill",
            "plugin",
            "command",
            "hook",
            "prompt",
            "template",
            "tool"
          ]
        },
        "name": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "agent-skill",
            "anthropic-plugin",
            "codex-plugin",
            "shell-command",
            "markdown-prompt",
            "template",
            "other"
          ]
        },
        "version": {
          "type": "string"
        },
        "entry": {
          "type": "string"
        },
        "homepage": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "install": {
          "$ref": "#/$defs/install"
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "integrity": {
          "$ref": "#/$defs/integrity"
        },
        "requiresExecution": {
          "type": "boolean"
        },
        "trust": {
          "type": "string",
          "enum": [
            "official",
            "verified",
            "community",
            "unknown"
          ]
        },
        "upstreamSource": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "plugin"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "format",
              "install"
            ],
            "properties": {
              "format": {
                "enum": [
                  "anthropic-plugin",
                  "codex-plugin",
                  "other"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "skill"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "format",
              "entry"
            ],
            "properties": {
              "format": {
                "const": "agent-skill"
              }
            }
          }
        }
      ]
    },
    "install": {
      "type": "object",
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "claude-marketplace",
            "git",
            "copy",
            "shell",
            "manual"
          ]
        },
        "marketplace": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "uninstall": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      }
    },
    "integrity": {
      "type": "object",
      "properties": {
        "checksum": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      }
    },
    "requirements": {
      "type": "object",
      "properties": {
        "agentPacks": {
          "type": "string"
        },
        "tools": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "skillRef": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "upstreamSource": {
              "type": "string"
            },
            "format": {
              "type": "string",
              "const": "agent-skill"
            },
            "version": {
              "type": "string"
            },
            "entry": {
              "type": "string"
            },
            "homepage": {
              "type": "string"
            },
            "repository": {
              "type": "string"
            },
            "license": {
              "type": "string"
            },
            "install": {
              "$ref": "#/$defs/install"
            },
            "trust": {
              "type": "string",
              "enum": [
                "official",
                "verified",
                "community",
                "unknown"
              ]
            }
          }
        }
      ]
    },
    "pluginRef": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "upstreamSource": {
              "type": "string"
            },
            "format": {
              "type": "string",
              "enum": [
                "anthropic-plugin",
                "codex-plugin",
                "other"
              ]
            },
            "version": {
              "type": "string"
            },
            "entry": {
              "type": "string"
            },
            "homepage": {
              "type": "string"
            },
            "repository": {
              "type": "string"
            },
            "license": {
              "type": "string"
            },
            "install": {
              "$ref": "#/$defs/install"
            },
            "trust": {
              "type": "string",
              "enum": [
                "official",
                "verified",
                "community",
                "unknown"
              ]
            }
          }
        }
      ]
    }
  },
  "anyOf": [
    {
      "required": [
        "capabilities"
      ]
    },
    {
      "required": [
        "packs"
      ]
    },
    {
      "required": [
        "skills"
      ]
    },
    {
      "required": [
        "plugins"
      ]
    }
  ]
}
