{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpacks.dev/schemas/agent-pack.schema.json",
  "title": "Agent Pack",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "description"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "packs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "required": [
        "type",
        "name",
        "source"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "skill",
            "plugin",
            "mcp",
            "command",
            "hook",
            "prompt",
            "template",
            "tool"
          ]
        },
        "name": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "agent-skill",
            "anthropic-plugin",
            "codex-plugin",
            "mcp-server",
            "shell-command",
            "markdown-prompt",
            "template",
            "other"
          ]
        },
        "version": {
          "type": "string"
        },
        "entry": {
          "type": "string"
        },
        "homepage": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "install": {
          "$ref": "#/$defs/install"
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "integrity": {
          "$ref": "#/$defs/integrity"
        },
        "requiresExecution": {
          "type": "boolean"
        },
        "trust": {
          "type": "string",
          "enum": [
            "official",
            "verified",
            "community",
            "unknown"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "plugin"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "format",
              "install"
            ],
            "properties": {
              "format": {
                "enum": [
                  "anthropic-plugin",
                  "codex-plugin",
                  "other"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "skill"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "format",
              "entry"
            ],
            "properties": {
              "format": {
                "const": "agent-skill"
              }
            }
          }
        }
      ]
    },
    "install": {
      "type": "object",
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "claude-marketplace",
            "git",
            "copy",
            "shell",
            "manual"
          ]
        },
        "marketplace": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      }
    },
    "integrity": {
      "type": "object",
      "properties": {
        "checksum": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      }
    }
  },
  "anyOf": [
    {
      "required": [
        "capabilities"
      ]
    },
    {
      "required": [
        "packs"
      ]
    },
    {
      "required": [
        "skills"
      ]
    },
    {
      "required": [
        "plugins"
      ]
    }
  ]
}
