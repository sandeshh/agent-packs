{
  "id": "real-world-agent-pack",
  "name": "Real World Agent Pack",
  "version": "0.1.0",
  "description": "Examples based on public Claude Code plugins and Agent Skills repositories.",
  "license": "Apache-2.0",
  "tags": [
    "claude-code",
    "plugins",
    "skills",
    "examples"
  ],
  "capabilities": [
    {
      "type": "plugin",
      "name": "Anthropic Claude Code code-review plugin",
      "source": "https://github.com/anthropics/claude-plugins-official/tree/main/plugins/code-review",
      "format": "anthropic-plugin",
      "entry": ".claude-plugin/plugin.json",
      "repository": "https://github.com/anthropics/claude-plugins-official",
      "homepage": "https://github.com/anthropics/claude-plugins-official",
      "install": {
        "method": "claude-marketplace",
        "marketplace": "claude-plugins-official",
        "package": "code-review",
        "command": "claude plugin install code-review@claude-plugins-official"
      },
      "requiresExecution": true,
      "trust": "community"
    },
    {
      "type": "plugin",
      "name": "Anthropic Knowledge Work sales plugin",
      "source": "https://github.com/anthropics/knowledge-work-plugins/tree/main/sales",
      "format": "anthropic-plugin",
      "entry": ".claude-plugin/plugin.json",
      "repository": "https://github.com/anthropics/knowledge-work-plugins",
      "homepage": "https://github.com/anthropics/knowledge-work-plugins",
      "install": {
        "method": "claude-marketplace",
        "marketplace": "knowledge-work-plugins",
        "package": "sales",
        "command": "claude plugin marketplace add anthropics/knowledge-work-plugins && claude plugin install sales@knowledge-work-plugins"
      },
      "requiresExecution": true,
      "trust": "community"
    },
    {
      "type": "plugin",
      "name": "Anthropic document skills plugin",
      "source": "https://github.com/anthropics/skills",
      "format": "anthropic-plugin",
      "entry": ".claude-plugin/plugin.json",
      "repository": "https://github.com/anthropics/skills",
      "homepage": "https://github.com/anthropics/skills",
      "install": {
        "method": "claude-marketplace",
        "marketplace": "anthropic-agent-skills",
        "package": "document-skills",
        "command": "claude plugin install document-skills@anthropic-agent-skills"
      },
      "requiresExecution": true,
      "trust": "community"
    },
    {
      "type": "skill",
      "name": "Microsoft Azure Agent Skills",
      "source": "https://github.com/MicrosoftDocs/Agent-Skills/tree/main/skills",
      "format": "agent-skill",
      "entry": "SKILL.md",
      "repository": "https://github.com/MicrosoftDocs/Agent-Skills",
      "homepage": "https://github.com/MicrosoftDocs/Agent-Skills",
      "targets": [
        ".claude/skills/",
        ".gemini/skills/",
        ".codex/skills/",
        ".github/skills/",
        ".cursor/skills/",
        ".agent/skills/"
      ]
    }
  ]
}
