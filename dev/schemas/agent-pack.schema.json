{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpacks.dev/schemas/agent-pack.schema.json",
  "title": "Agent Pack",
  "type": "object",
  "required": ["id", "name", "version", "description", "capabilities"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name", "source"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["skill", "plugin", "mcp", "command", "hook", "prompt", "template", "tool"]
          },
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      }
    }
  }
}

